---
import PageLayout from '@/layouts/CommonPage.astro'
import bandsData from '../../data/bands.json'
import moviesData from '../../data/douban/movies.json'
import booksData from '../../data/douban/books.json'
import ytSubsData from '../../data/youtube-subs.json'

type DoubanItem = {
  title: string
  original_title?: string | null
  intro?: string | null
  url?: string | null
  cover?: string | null
  rating?: number | null
  date?: string | null
  comment?: string | null
}

type Band = {
  slug: string
  display: string
  link: string
  avatar: string | null
}

type BandsPayload = {
  count: number
  updated_at: string
  items: Band[]
}

type DoubanPayload = {
  user_id: string
  count: number
  updated_at: string
  items: DoubanItem[]
}

type YoutubeSubItem = {
  id: string
  url: string
  title: string
  avatar: string | null
}

type YoutubeSubsPayload = {
  count: number
  updated_at: string
  items: YoutubeSubItem[]
}

const movies = moviesData as DoubanPayload
const books = booksData as DoubanPayload
const ytSubs = ytSubsData as YoutubeSubsPayload
const bands = bandsData as BandsPayload

// 豆瓣图片有 referer 防盗链，浏览器直连大概率 403。
// 脚本里已经把封面下到 public/images/douban/，cover 字段是站内相对路径
// （形如 /images/douban/p123.webp）。这里只判断一下是不是本地路径，
// 不是的话就当作没有封面（避免又跑去拉豆瓣）。
function resolveCover(url: string | null | undefined): string | null {
  if (!url) return null
  if (url.startsWith('/images/douban/')) return url
  return null
}

const headings = [
  { depth: 2, slug: 'youtube', text: '📺 YouTube 订阅频道' },
  { depth: 2, slug: 'bands', text: '🎵 乐队' },
  { depth: 2, slug: 'movies', text: '🎬 电影' },
  { depth: 2, slug: 'books', text: '📚 书籍' }
]

const sections: { id: string; title: string; payload: DoubanPayload; emptyHint: string }[] = [
  {
    id: 'movies',
    title: '🎬 电影',
    payload: movies,
    emptyHint: '还没有数据。运行 `python scripts/douban_sync.py movie` 同步。'
  },
  {
    id: 'books',
    title: '📚 书籍',
    payload: books,
    emptyHint: '还没有数据。运行 `python scripts/douban_sync.py book` 同步。'
  }
]
---

<PageLayout title='娱乐' {headings}>
  {/* YouTube 订阅频道 */}
  <section>
    <h2 id='youtube'>
      📺 YouTube 订阅频道
      <span class='ml-2 text-sm font-normal text-muted-foreground'>
        共 {ytSubs.count} 个
      </span>
    </h2>

    {ytSubs.items.length === 0 ? (
      <p class='text-sm text-muted-foreground'>
        还没有数据。运行 <code>npm run sync:youtube</code> 同步。
      </p>
    ) : (
      <div class='not-prose grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5'>
        {ytSubs.items.map((c) => (
          <a
            href={c.url}
            target='_blank'
            rel='noopener noreferrer'
            class='group flex flex-col items-center gap-y-2 rounded-lg border bg-background/60 p-3 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md'
          >
            <div class='aspect-square w-20 overflow-hidden rounded-full bg-muted'>
              {c.avatar ? (
                <img
                  src={c.avatar}
                  alt={c.title}
                  loading='lazy'
                  class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-105'
                />
              ) : (
                <div class='flex h-full w-full items-center justify-center text-xs text-muted-foreground'>
                  无头像
                </div>
              )}
            </div>
            <h3
              class='line-clamp-2 text-center text-sm font-medium leading-snug group-hover:text-[var(--primary)]'
              title={c.title}
            >
              {c.title}
            </h3>
          </a>
        ))}
      </div>
    )}
  </section>

  {/* 乐队 */}
  <section>
    <h2 id='bands'>
      🎵 乐队
      <span class='ml-2 text-sm font-normal text-muted-foreground'>共 {bands.count} 个</span>
    </h2>

    <div class='not-prose grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5'>
      {
        bands.items.map((b) => (
          <a
            href={b.link}
            target='_blank'
            rel='noopener noreferrer'
            class='group flex flex-col items-center gap-y-2 rounded-lg border bg-background/60 p-3 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md'
          >
            <div class='aspect-square w-20 overflow-hidden rounded-full bg-muted'>
              {b.avatar ? (
                <img
                  src={b.avatar}
                  alt={b.display}
                  loading='lazy'
                  class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-105'
                />
              ) : (
                <div class='flex h-full w-full items-center justify-center text-xs text-muted-foreground'>
                  无头像
                </div>
              )}
            </div>
            <h3
              class='line-clamp-2 text-center text-sm font-medium leading-snug group-hover:text-[var(--primary)]'
              title={b.display}
            >
              {b.display}
            </h3>
          </a>
        ))
      }
    </div>
  </section>

  {
    sections.map(({ id, title, payload, emptyHint }) => (
      <section>
        <h2 id={id}>
          {title}
          <span class='ml-2 text-sm font-normal text-muted-foreground'>
            共 {payload.count} 条
          </span>
        </h2>

        {payload.items.length === 0 ? (
          <p class='text-sm text-muted-foreground'>{emptyHint}</p>
        ) : (
          <div class='not-prose grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5'>
            {payload.items.map((it) => (
              <a
                href={it.url ?? '#'}
                target='_blank'
                rel='noopener noreferrer'
                class='group flex flex-col overflow-hidden rounded-lg border bg-background/60 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md'
              >
                <div class='aspect-[2/3] overflow-hidden bg-muted'>
                  {resolveCover(it.cover) ? (
                    <img
                      src={resolveCover(it.cover)!}
                      alt={it.title}
                      loading='lazy'
                      class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-105'
                    />
                  ) : (
                    <div class='flex h-full w-full items-center justify-center text-xs text-muted-foreground'>
                      无封面
                    </div>
                  )}
                </div>
                <div class='flex flex-1 flex-col gap-y-1 p-2.5'>
                  <h3
                    class='line-clamp-2 text-sm font-medium leading-snug group-hover:text-[var(--primary)]'
                    title={it.title}
                  >
                    {it.title}
                  </h3>

                  {/* 星评：把 1-5 转成实心 / 空心五角星 */}
                  {it.rating ? (
                    <div
                      class='text-xs leading-none text-amber-500'
                      aria-label={`${it.rating} 星`}
                      title={`${it.rating} / 5`}
                    >
                      {'★'.repeat(it.rating)}
                      <span class='text-muted-foreground/40'>
                        {'★'.repeat(5 - it.rating)}
                      </span>
                    </div>
                  ) : (
                    <div class='text-xs text-muted-foreground/60'>未评分</div>
                  )}

                  {it.date && (
                    <p class='mt-auto text-xs text-muted-foreground/80'>{it.date}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        )}
      </section>
    ))
  }
</PageLayout>
