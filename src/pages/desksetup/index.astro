---
import { getCollection, render } from 'astro:content'
import PageLayout from '@/layouts/CommonPage.astro'

const entries = (await getCollection('desksetup', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
)

const formatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
})

const rendered = await Promise.all(
  entries.map(async (e) => {
    const { Content } = await render(e)
    return { entry: e, Content, label: formatter.format(e.data.publishDate) }
  })
)

type Device = {
  name: string
  image: string
  specs: string
  date: string
  link: string
}

function thumbnailPath(image: string): string {
  return image
    .replace(/^\/images\/(device|desksetup)\//, '/images/$1/thumbs/')
    .replace(/\.[^.]+$/, '.webp')
}

