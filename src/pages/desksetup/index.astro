---

<PageLayout title='桌搭' {headings}>
  <h2 id='timeline'>🪴 时间线</h2>
  <p class='text-muted-foreground'>共 {entries.length} 条 · 按日期时间线排列</p>

  <ol class='not-prose mt-6 relative ms-3 border-s border-muted-foreground/30'>
    {
      rendered.map(({ entry, Content, label }) => (
        <li class='ms-6 mb-8 last:mb-0'>
          {/* timeline dot */}
          <span class='absolute -start-[7px] mt-1.5 size-3 rounded-full border-2 border-background bg-[var(--primary)]' />
          <time class='block text-xs font-medium text-muted-foreground mb-2'>{label}</time>
          <div class='max-w-xl overflow-hidden rounded-lg border bg-background/60 shadow-sm md:flex'>
            {entry.data.image && (
              <a
                href={entry.data.image}
                target='_blank'
                rel='noopener'
                class='block shrink-0 md:w-40'
              >
                <img
                  src={thumbnailPath(entry.data.image)}
                  alt={`桌搭 ${label}`}
                  width='1200'
                  height='900'
                  class='h-32 w-full object-cover md:h-full'
                  loading='lazy'
                  decoding='async'
                />
              </a>
            )}
            <div class='p-3 md:flex-1'>
              <div class='prose prose-sm max-w-none dark:prose-invert text-sm'>
                <Content />
              </div>
            </div>
          </div>
        </li>
      ))
    }
  </ol>

  {
    deviceSections.map((section) => (
      <section>
        <h2 id={section.id}>{section.title}</h2>
        <div class='not-prose grid grid-cols-3 gap-2 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6'>
          {section.items.map((d) => (
            <a
              href={d.link}
              target='_blank'
              rel='noopener'
              class='group flex flex-col overflow-hidden rounded-lg border bg-background/60 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md'
            >
              <div class='aspect-square overflow-hidden bg-muted'>
                <img
                  src={thumbnailPath(d.image)}
                  alt={d.name}
                  width='480'
                  height='480'
                  loading='lazy'
                  decoding='async'
                  class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-105'
                />
              </div>
              <div class='flex flex-1 flex-col gap-y-0.5 p-2'>
                <h3 class='line-clamp-2 text-xs font-medium leading-snug group-hover:text-[var(--primary)]'>
                  {d.name}
                </h3>
                <p class='line-clamp-2 text-[10px] text-muted-foreground leading-tight'>
                  {d.specs}
                </p>
                <p class='mt-auto text-[10px] text-muted-foreground/80'>{d.date}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))
  }
</PageLayout>
