---
import { getCollection, render } from 'astro:content'
import PageLayout from '@/layouts/CommonPage.astro'

const entries = (await getCollection('desksetup', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
)

const formatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
})

const rendered = await Promise.all(
  entries.map(async (e) => {
    const { Content } = await render(e)
    return { entry: e, Content, label: formatter.format(e.data.publishDate) }
  })
)
---

<PageLayout title='桌搭'>
  <p class='text-muted-foreground'>共 {entries.length} 条 · 按日期时间线排列</p>

  <ol class='not-prose mt-8 relative ms-3 border-s border-muted-foreground/30'>
    {
      rendered.map(({ entry, Content, label }) => (
        <li class='ms-6 mb-10 last:mb-0'>
          {/* timeline dot */}
          <span class='absolute -start-[7px] mt-1.5 size-3.5 rounded-full border-2 border-background bg-[var(--primary)]' />
          <time class='block text-sm font-medium text-muted-foreground mb-3'>{label}</time>
          <div class='overflow-hidden rounded-lg border bg-background/60 shadow-sm md:flex'>
            {entry.data.image && (
              <a
                href={entry.data.image}
                target='_blank'
                rel='noopener'
                class='block shrink-0 md:w-56'
              >
                <img
                  src={entry.data.image}
                  alt={`桌搭 ${label}`}
                  class='h-44 w-full object-cover md:h-full'
                  loading='lazy'
                />
              </a>
            )}
            <div class='p-4 md:flex-1'>
              <div class='prose prose-sm max-w-none dark:prose-invert'>
                <Content />
              </div>
            </div>
          </div>
        </li>
      ))
    }
  </ol>
</PageLayout>
