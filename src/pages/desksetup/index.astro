const headings = [
  { depth: 2, slug: 'timeline', text: '🪴 时间线' },
  { depth: 2, slug: 'apple', text: '🍎 Apple' },
  { depth: 2, slug: 'peripherals', text: '🖥️ 外设' },
  { depth: 2, slug: 'audio', text: '🎧 发烧' }
