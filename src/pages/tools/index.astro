---
import PageLayout from '@/layouts/CommonPage.astro'

// 工具栏数据：后续要加新工具，往下面这个数组里追加一项即可。
// description 不是必填——没写就不在卡片里显示描述行。
type Tool = {
  title: string
  href: string
  description?: string
}

const tools: Tool[] = [
  {
    title: 'AyayaMarkdown',
    href: 'https://ayaya114514.github.io/AyayaMarkdown/',
    description: '在线Markdown编辑器'
  },
  {
    title: 'AyayaJp',
    href: 'https://ayaya114514.github.io/AyayaJp/',
    description: '日语练习'
  },
  {
    title: 'GitPulse',
    href: 'https://gitpulse-one.vercel.app/',
    description: '在线 GitHub 总结图'
  },
  {
    title: 'AyayaPrompt',
    href: 'https://ayaya114514.github.io/AyayaPrompt/',
    description: '本地优先的 Prompt 管理、版本历史与模型 Playground'
  }
]

const headings = [{ depth: 2, slug: 'tools', text: '🛠 工具' }]
---

<PageLayout title='工具' description='收集和分享我制作或常用的在线小工具。' {headings}>
  <section>
    <h2 id='tools'>
      🛠 工具
      <span class='ml-2 text-sm font-normal text-muted-foreground'>共 {tools.length} 个</span>
    </h2>

    <div class='not-prose grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3'>
      {
        tools.map((t) => (
          <a
            href={t.href}
            target='_blank'
            rel='noopener noreferrer'
            class='group flex flex-col gap-y-1.5 rounded-lg border bg-background/60 p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md'
          >
            <h3 class='text-base font-medium leading-snug group-hover:text-[var(--primary)]'>
              {t.title}
            </h3>
            {t.description && <p class='text-sm text-muted-foreground'>{t.description}</p>}
            <p class='mt-auto truncate pt-1 text-xs text-muted-foreground/70'>{t.href}</p>
          </a>
        ))
      }
    </div>
  </section>
</PageLayout>
