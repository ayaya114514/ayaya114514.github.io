---
import PageLayout from '@/layouts/CommonPage.astro'

// 工具栏数据：后续要加新工具，往下面这个数组里追加一项即可。
// description 不是必填——没写就不在卡片里显示描述行。
type Tool = {
  title: string
  href: string
  description?: string
}

const tools: Tool[] = [
  {
    title: 'AyayaMarkdown',
    href: 'https://ayaya114514.github.io/AyayaMarkdown/',
    description: '在线Markdown编辑器'
  },
  {
    title: 'AyayaJp',
    href: 'https://ayaya114514.github.io/AyayaJp/',
    description: '日语练习'
  },
  {
    title: 'AyayaVpsCalculator',
    href: 'https://ayaya114514.github.io/AyayaVpsCalculator/',
    description: 'VPS 剩余价值计算器'
  },
  {
    title: 'AyayaGitSum',
    href: 'https://ayaya114514.github.io/gitpulse/',
    description: '简洁的 GitHub 开发者概览'
  },
  {
    title: 'AyayaPrompt',
    href: 'https://ayaya114514.github.io/AyayaPrompt/',
    description: '本地优先的 Prompt 管理、版本历史与模型 Playground'
  }
]

const abbreviationOf = (title: string) => title.match(/[A-Z]/g)?.join('') ?? ''
---

<PageLayout title='工具' description='收集和分享我制作或常用的在线小工具。'>
  <section>
    <p class='text-sm text-muted-foreground'>共 {tools.length} 个</p>

    <div class='not-prose mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3'>
      {
        tools.map((t) => (
          <a
            href={t.href}
            target='_blank'
            rel='noopener noreferrer'
            class='group flex flex-col gap-y-1.5 rounded-lg border bg-background/60 p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md'
          >
            <h3 class='flex flex-wrap items-center gap-x-2 gap-y-1 text-base font-medium leading-snug group-hover:text-[var(--primary)]'>
              <span>{t.title}</span>
              <span
                class='inline-flex rounded border border-muted-foreground/35 px-1.5 py-0.5 text-[10px] font-semibold leading-none tracking-wide text-muted-foreground transition-colors group-hover:border-[var(--primary)]/50 group-hover:text-[var(--primary)]'
                aria-label={`${t.title} 缩写`}
              >
                {abbreviationOf(t.title)}
              </span>
            </h3>
            {t.description && <p class='text-sm text-muted-foreground'>{t.description}</p>}
            <p class='mt-auto truncate pt-1 text-xs text-muted-foreground/70'>{t.href}</p>
          </a>
        ))
      }
    </div>
  </section>
</PageLayout>
