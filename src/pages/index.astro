---
import { Image } from 'astro:assets'

import { Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import Section from '@/components/home/Section.astro'
import config from '@/site-config'

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ description: config.description, title: '首页' }} showSidebar={false}>
  <main class='flex w-full flex-col items-center'>
    {/* Hero */}
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex w-full flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div
          class='grid w-full max-w-lg grid-cols-4 gap-x-2 text-[11px] sm:flex sm:w-auto sm:gap-x-7 sm:text-base'
        >
          <Label
            title='GitHub'
            as='a'
            href='https://github.com/ayaya114514'
            target='_blank'
            rel='noopener noreferrer'
            class='min-w-0 gap-x-1 sm:gap-x-2'
          >
            <Icon name='github' class='size-4 sm:size-5' slot='icon' />
          </Label>
          <Label
            title='Linux.do'
            as='a'
            href='https://linux.do/u/ayaya114514/summary'
            target='_blank'
            rel='noopener noreferrer'
            class='min-w-0 gap-x-1 sm:gap-x-2'
          >
            <svg
              class='size-4 shrink-0 sm:size-5'
              slot='icon'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='1.8'
              stroke-linecap='round'
              stroke-linejoin='round'
              aria-hidden='true'
            >
              <circle cx='12' cy='12' r='9'></circle>
              <path d='M3.9 8.5h16.2M3.9 15.5h16.2'></path>
            </svg>
          </Label>
          <Label
            title='IDC Flare'
            as='a'
            href='https://idcflare.com/u/ayaya114514/summary'
            target='_blank'
            rel='noopener noreferrer'
            class='min-w-0 gap-x-1 sm:gap-x-2'
          >
            <svg
              class='size-4 shrink-0 sm:size-5'
              slot='icon'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='1.8'
              stroke-linecap='round'
              stroke-linejoin='round'
              aria-hidden='true'
            >
              <circle cx='12' cy='12' r='9'></circle>
              <path d='M7.5 8v8M11 16V8h5.5M11 12h4.5'></path>
            </svg>
          </Label>
          <Label
            title='NodeSeek'
            as='a'
            href='https://www.nodeseek.com/space/50733#/general'
            target='_blank'
            rel='noopener noreferrer'
            class='min-w-0 gap-x-1 sm:gap-x-2'
          >
            <svg
              class='size-4 shrink-0 sm:size-5'
              slot='icon'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='1.8'
              stroke-linecap='round'
              aria-hidden='true'
            >
              <circle cx='12' cy='12' r='1.4' fill='currentColor' stroke='none'></circle>
              <path d='M8.6 8.4a5.1 5.1 0 0 0 0 7.2M15.4 8.4a5.1 5.1 0 0 1 0 7.2'></path>
              <path d='M5.8 6.2a8.2 8.2 0 0 0 0 11.6M18.2 6.2a8.2 8.2 0 0 1 0 11.6'></path>
            </svg>
          </Label>
        </div>
        <div class='flex justify-center gap-x-7'>
          <Label
            title='Instagram'
            as='a'
            href='https://www.instagram.com/luanzhui1/'
            target='_blank'
            rel='noopener noreferrer'
          >
            <Icon name='instagram' class='size-5' slot='icon' />
          </Label>
          <Label
            title='Bilibili'
            as='a'
            href='https://space.bilibili.com/431279208'
            target='_blank'
            rel='noopener noreferrer'
          >
            <Icon name='bilibili' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 w-full md:w-11/12 xl:w-full max-w-5xl'>
      {/* Help */}
      <Section title='有什么可以帮助到你'>
        <p class='text-muted-foreground leading-relaxed'>
          日本帝大情报修考的情报、直连 / 中转 / IEPL 专线机场的推荐、亚太 / 美西等地区的线路机 /
          落地机 VPS 厂家的推荐、链式代理 / 分流规则 / 代理软件的使用教程、主流 LLM
          模型不同版本的斗蛐蛐、正价订阅 Claude / ChatGPT
          全流程等，如有需要请务必联络我，我会耐心免费为您解答的！
        </p>
      </Section>

      {/* Contact */}
      <Section title='联络先'>
        <a
          href='mailto:anyangyang2022@gmail.com'
          class='inline-flex w-fit items-center gap-x-2 rounded-lg border bg-background/60 px-3 py-2 text-sm shadow-sm select-all'
        >
          <Icon name='email' class='size-4' />
          anyangyang2022@gmail.com
        </a>
      </Section>
    </div>
  </main>
</PageLayout>
