---
import { Image } from 'astro:assets'
import { getCollection, render } from 'astro:content'

import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import Section from '@/components/home/Section.astro'
import config from '@/site-config'

const MAX_POSTS = 5
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

const desksetupEntries = (
  await getCollection('desksetup', ({ data }) => !data.draft)
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
const recentDesksetup = desksetupEntries.slice(0, 3)
const dateFmt = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
})

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }}>
  <main class='flex w-full flex-col items-center'>
    {/* Hero */}
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='Somewhere'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label title='学生'>
            <Icon name='user' class='size-5' slot='icon' />
          </Label>
          <Label title='GitHub' as='a' href='https://github.com/ayaya114514' target='_blank'>
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
        <p class='italic text-muted-foreground text-sm'>{config.description}</p>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      {/* About */}
      <Section title='关于'>
        <p class='text-muted-foreground'>
          这里是 ayaya 的小角落，主要用来存放笔记和日常碎念。
        </p>
        <Button title='了解更多...' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>

      {/* Recent posts */}
      {
        allPostsByDate.length > 0 && (
          <Section title='笔记'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='更多笔记' class='w-fit self-end' href='/blog' variant='ahead' />
          </Section>
        )
      }

      {/* Recent desk setup */}
      {
        recentDesksetup.length > 0 && (
          <Section title='桌搭'>
            <ul class='flex flex-col gap-y-3'>
              {recentDesksetup.map((entry) => (
                <li>
                  <a
                    href='/desksetup'
                    class='flex items-center gap-x-4 rounded-lg border bg-background/40 p-3 transition-colors hover:bg-muted'
                  >
                    {entry.data.image && (
                      <img
                        src={entry.data.image}
                        alt={`桌搭 ${dateFmt.format(entry.data.publishDate)}`}
                        class='size-16 shrink-0 rounded object-cover'
                        loading='lazy'
                      />
                    )}
                    <div class='min-w-0 flex-1'>
                      <p class='text-sm font-medium'>
                        {dateFmt.format(entry.data.publishDate)}
                      </p>
                      <p class='line-clamp-2 text-xs text-muted-foreground mt-1'>
                        {entry.body?.slice(0, 60)}
                      </p>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
            <Button title='更多桌搭' class='w-fit self-end' href='/desksetup' variant='ahead' />
          </Section>
        )
      }

      {/* Devices */}
      <Section title='设备'>
        <p class='text-muted-foreground text-sm'>日常使用的各种数码 / 外设 / 音频设备。</p>
        <Button title='查看设备' class='w-fit self-end' href='/devices' variant='ahead' />
      </Section>
    </div>
  </main>
</PageLayout>
