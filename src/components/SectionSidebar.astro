---
import { getCollection } from 'astro:content'

import config from '@/site-config'
import SectionSubmenu from '@/components/SectionSubmenu.astro'

interface Props {
  showDesktop?: boolean
  hasSubNav?: boolean
}

const { showDesktop = true } = Astro.props
const sections = config.header.menu ?? []
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'
const posts = await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft : true))
const currentBlogId = currentPath.startsWith('/blog/')
  ? decodeURIComponent(currentPath.slice('/blog/'.length))
  : undefined
---

<!-- ===== 桌面端侧边栏 ===== -->
<aside
  class={`hidden ${showDesktop ? 'lg:flex' : ''} sticky top-20 self-start w-56 shrink-0 me-8 mt-20 flex-col gap-y-1 max-h-[calc(100vh-6rem)] overflow-y-auto bg-transparent`}
  aria-label='桌面侧栏导航'
  data-section-menu
>
  {
    sections.map((s, index) => {
      const active =
        s.link === '/'
          ? currentPath === '/'
          : currentPath === s.link || currentPath.startsWith(s.link + '/')
      const panelId = `desktop-section-${index}`
      return (
        <div class='flex flex-col'>
          <button
            type='button'
            aria-expanded='false'
            aria-controls={panelId}
            data-section-toggle
            class={`flex w-full items-center justify-between px-3 py-2 rounded-md text-sm font-medium transition-colors hover:bg-muted ${
              active ? 'bg-muted text-[var(--primary)]' : 'text-muted-foreground'
            }`}
          >
            <span>{s.title}</span>
            <svg
              class='section-chevron h-3.5 w-3.5 shrink-0 transition-transform'
              viewBox='0 0 20 20'
              fill='currentColor'
              aria-hidden='true'
            >
              <path d='M7.05 4.55a.75.75 0 0 1 1.06 0l4.9 4.9a.75.75 0 0 1 0 1.06l-4.9 4.9a.75.75 0 0 1-1.06-1.06L11.38 10 7.05 5.61a.75.75 0 0 1 0-1.06Z' />
            </svg>
          </button>

          {/* 一级菜单只负责展开；子标题或目录项才负责实际跳转。 */}
          <div
            id={panelId}
            data-section-panel
            class='mt-1 mb-2 ms-3 ps-3 border-l border-muted-foreground/20'
            hidden
          >
            <SectionSubmenu section={s} {posts} {currentBlogId} />
          </div>
        </div>
      )
    })
  }
</aside>

<!-- ===== 移动端：滑出抽屉（由 Header 的汉堡按钮触发） ===== -->
<div id='mobile-sidebar-root' class='lg:hidden'>
  <!-- 半透明遮罩 -->
  <div
    id='mobile-sidebar-backdrop'
    class='fixed inset-0 z-40 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300'
    aria-hidden='true'
    hidden
  >
  </div>

  <!-- 抽屉面板 -->
  <div
    id='mobile-sidebar-drawer'
    class='fixed inset-y-0 start-0 z-50 flex w-72 max-w-[85vw] flex-col bg-background border-e border-border shadow-2xl -translate-x-full transition-transform duration-300 ease-out'
    role='dialog'
    aria-modal='true'
    aria-label='导航菜单'
    aria-hidden='true'
    inert
    hidden
  >
    <!-- 抽屉头部：标题 + 关闭按钮 -->
    <div class='flex items-center justify-between px-4 py-3 border-b border-border'>
      <span class='text-sm font-medium text-muted-foreground'>导航</span>
      <button
        id='mobile-sidebar-close'
        class='rounded-md p-1.5 transition-colors hover:bg-muted'
        aria-label='关闭侧边栏'
      >
        <svg class='h-4 w-4' viewBox='0 0 20 20' fill='currentColor' aria-hidden='true'>
          <path
            d='M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 0 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 0 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z'
          ></path>
        </svg>
      </button>
    </div>

    <!-- 抽屉内容：与桌面侧边栏相同的导航 + 子板块 -->
    <nav
      class='flex-1 overflow-y-auto px-3 py-4'
      aria-label='移动侧栏导航'
      data-section-menu
    >
      {
        sections.map((s, index) => {
          const active =
            s.link === '/'
              ? currentPath === '/'
              : currentPath === s.link || currentPath.startsWith(s.link + '/')
          const panelId = `mobile-section-${index}`
          return (
            <div class='flex flex-col'>
              <button
                type='button'
                aria-expanded='false'
                aria-controls={panelId}
                data-section-toggle
                class={`flex w-full items-center justify-between px-3 py-2.5 rounded-md text-sm font-medium transition-colors hover:bg-muted ${
                  active ? 'bg-muted text-[var(--primary)]' : 'text-muted-foreground'
                }`}
              >
                <span>{s.title}</span>
                <svg
                  class='section-chevron h-3.5 w-3.5 shrink-0 transition-transform'
                  viewBox='0 0 20 20'
                  fill='currentColor'
                  aria-hidden='true'
                >
                  <path d='M7.05 4.55a.75.75 0 0 1 1.06 0l4.9 4.9a.75.75 0 0 1 0 1.06l-4.9 4.9a.75.75 0 0 1-1.06-1.06L11.38 10 7.05 5.61a.75.75 0 0 1 0-1.06Z' />
                </svg>
              </button>

              <div
                id={panelId}
                data-section-panel
                class='mt-1 mb-2 ms-3 ps-3 border-l border-muted-foreground/20'
                hidden
              >
                <SectionSubmenu section={s} {posts} {currentBlogId} />
              </div>
            </div>
          )
        })
      }
    </nav>
  </div>
</div>

<script>
  function initSectionMenus() {
    document.querySelectorAll<HTMLElement>('[data-section-menu]').forEach((menu) => {
      const toggles = Array.from(menu.querySelectorAll<HTMLButtonElement>('[data-section-toggle]'))

      toggles.forEach((toggle) => {
        toggle.addEventListener('click', () => {
          const wasExpanded = toggle.getAttribute('aria-expanded') === 'true'

          toggles.forEach((item) => {
            item.setAttribute('aria-expanded', 'false')
            const panelId = item.getAttribute('aria-controls')
            const panel = panelId ? document.getElementById(panelId) : null
            if (panel) panel.hidden = true
          })

          if (!wasExpanded) {
            toggle.setAttribute('aria-expanded', 'true')
            const panelId = toggle.getAttribute('aria-controls')
            const panel = panelId ? document.getElementById(panelId) : null
            if (panel) {
              panel.hidden = false
              // SectionNav 在折叠状态下无法得到正确尺寸；展开后通知它重新定位高亮块。
              requestAnimationFrame(() => window.dispatchEvent(new Event('resize')))
            }
          }
        })
      })
    })
  }

  function initMobileSidebar() {
    const close = document.getElementById('mobile-sidebar-close')
    const backdrop = document.getElementById('mobile-sidebar-backdrop')
    const drawer = document.getElementById('mobile-sidebar-drawer')
    const root = document.getElementById('mobile-sidebar-root')
    const toggle = document.getElementById('toggleMenu')

    if (!close || !backdrop || !drawer || !root || !toggle) return
    const closeButton = close
    const backdropEl = backdrop
    const drawerEl = drawer
    const rootEl = root
    const toggleButton = toggle
    const inertSiblings: HTMLElement[] = []
    let lastFocused: HTMLElement | null = null
    let hideTimer: number | undefined

    const focusableSelector =
      'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'

    function setBackgroundInert(value: boolean) {
      if (value) {
        inertSiblings.length = 0
        for (const sibling of Array.from(rootEl.parentElement?.children ?? [])) {
          if (sibling !== rootEl && sibling instanceof HTMLElement && !sibling.inert) {
            sibling.inert = true
            inertSiblings.push(sibling)
          }
        }
        return
      }
      for (const sibling of inertSiblings) sibling.inert = false
      inertSiblings.length = 0
    }

    function open() {
      if (hideTimer) window.clearTimeout(hideTimer)
      lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null
      backdropEl.hidden = false
      drawerEl.hidden = false
      drawerEl.removeAttribute('inert')
      drawerEl.setAttribute('aria-hidden', 'false')
      toggleButton.setAttribute('aria-expanded', 'true')
      setBackgroundInert(true)
      document.body.style.overflow = 'hidden'
      requestAnimationFrame(() => {
        drawerEl.classList.remove('-translate-x-full')
        backdropEl.classList.remove('opacity-0', 'pointer-events-none')
        closeButton.focus()
      })
    }

    function close_(restoreFocus = true) {
      drawerEl.setAttribute('inert', '')
      drawerEl.setAttribute('aria-hidden', 'true')
      drawerEl.classList.add('-translate-x-full')
      backdropEl.classList.add('opacity-0', 'pointer-events-none')
      toggleButton.setAttribute('aria-expanded', 'false')
      setBackgroundInert(false)
      document.body.style.overflow = ''
      if (restoreFocus) lastFocused?.focus()
      hideTimer = window.setTimeout(() => {
        if (drawerEl.getAttribute('aria-hidden') === 'true') {
          drawerEl.hidden = true
          backdropEl.hidden = true
        }
      }, 300)
    }

    // 暴露给 Header 的汉堡按钮调用
    window.__openMobileSidebar = open

    closeButton.addEventListener('click', () => close_())
    backdropEl.addEventListener('click', () => close_())
    drawerEl.querySelectorAll('a[href]').forEach((link) => {
      link.addEventListener('click', () => close_(false))
    })

    // 按 Escape 关闭；Tab / Shift+Tab 始终限制在 modal drawer 内。
    document.addEventListener('keydown', (e) => {
      if (drawerEl.classList.contains('-translate-x-full')) return
      if (e.key === 'Escape') {
        close_()
        return
      }
      if (e.key !== 'Tab') return

      const focusable = Array.from(drawerEl.querySelectorAll<HTMLElement>(focusableSelector))
      if (focusable.length === 0) return
      const first = focusable[0]
      const last = focusable[focusable.length - 1]
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault()
        last.focus()
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault()
        first.focus()
      }
    })
  }

  initSectionMenus()
  initMobileSidebar()
</script>

<style>
  [data-section-toggle][aria-expanded='true'] .section-chevron {
    transform: rotate(90deg);
  }
</style>
