---
import { Icon } from 'astro-pure/user'
import config from '@/site-config'

const sections = config.header.menu ?? []
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'
---

<header-component
  class='group sticky top-4 z-50 max-md:z-30 mb-12 flex items-center justify-between rounded-xl border border-transparent max-sm:py-1 sm:rounded-2xl'
>
  <div class='z-30 flex items-center'>
    <button
      id='toggleMenu'
      class='rounded-md border p-1.5 transition-colors hover:bg-border lg:hidden lg:group-[.not-top]:rounded-xl'
      aria-label='打开导航菜单'
      aria-controls='mobile-sidebar-drawer'
      aria-expanded='false'
    >
      <Icon class='size-5' name='menu' />
    </button>

    <a
      class='hidden text-xl font-medium group-[.not-top]:ms-2 lg:block sm:group-[.not-top]:ms-3'
      style='transition:margin-inline 0.3s'
      href='/'
      aria-label='返回首页'>ayaya</a
    >
  </div>

  <div class='flex items-center gap-x-2'>
    {/* Menu links */}
    <nav id='headerExpandContent' class='hidden lg:grid lg:grid-rows-1' aria-label='主导航'>
      <div class='flex flex-col items-center justify-center overflow-hidden lg:flex-row'>
        {
          sections.map((item) => (
            <a
              href={item.link}
              class='w-full flex-none grow py-2 max-lg:text-center lg:text-right font-medium transition-none hover:text-primary lg:w-fit lg:px-3'
              aria-current={
                item.link === '/'
                  ? currentPath === '/'
                    ? 'page'
                    : undefined
                  : currentPath === item.link || currentPath.startsWith(item.link + '/')
                    ? 'page'
                    : undefined
              }
              data-astro-prefetch
            >
              {item.title}
            </a>
          ))
        }
      </div>
    </nav>
  </div>
</header-component>

<script>
  class HeaderComponent extends HTMLElement {
    connectedCallback() {
      // Sticky header scroll state
      let preScrollY = window.scrollY
      this.classList.toggle('not-top', preScrollY > 20)
      window.addEventListener('scroll', () => {
        this.classList.toggle('not-top', window.scrollY > 20)
        this.dataset.show = (window.scrollY < 350 || window.scrollY < preScrollY).toString()
        preScrollY = window.scrollY
      })

      // Mobile menu
      this.querySelector('#toggleMenu')?.addEventListener('click', () => {
        window.__openMobileSidebar?.()
      })
    }
  }

  if (!customElements.get('header-component')) {
    customElements.define('header-component', HeaderComponent)
  }
</script>

<style>
  header-component {
    transition:
      padding 0.3s,
      transform 0.3s,
      margin-inline 0.3s,
      border 0.15s,
      background-color 0.15s;

    &.not-top {
      --un-border-opacity: 1;
      border-color: hsl(var(--border) / var(--un-border-opacity));
      --un-bg-opacity: 1;
      background-color: hsl(var(--background) / var(--un-bg-opacity));
      padding-left: 0.375rem;
      padding-right: 0.375rem;
      box-shadow:
        rgb(255, 255, 255) 0px 0px 0px 0px,
        rgba(24, 24, 27, 0.08) 0px 0px 0px 1px,
        rgba(39, 39, 42, 0.08) 0px 10px 15px -3px,
        rgba(39, 39, 42, 0.08) 0px 4px 6px -4px;
    }
    &[data-show='false'] {
      transform: translateY(-5rem);
    }
  }
  @media (min-width: 800px) {
    header-component.not-top {
      margin-inline: 8%;
    }
  }
  :global(.dark) header-component.not-top {
    background-color: hsl(var(--muted) / var(--un-bg-opacity));
  }
</style>
