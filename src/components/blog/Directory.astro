---
import type { CollectionEntry } from 'astro:content'

interface Props {
  posts: CollectionEntry<'blog'>[]
  currentId?: string
  class?: string
}

const { posts, currentId, class: className } = Astro.props

// 按 id 升序排，确保形如 "00-prelude" 这类带序号的笔记排在前面
const sortedPosts = [...posts].sort((a, b) => a.id.localeCompare(b.id))

// 子项目展示名映射：原始目录 slug -> 中文名。若未配置则回退到原 slug
const groupNameMap: Record<string, string> = {
  'machine-learning': '机器学习',
  'paper-digest': '论文抓取',
  miscellaneous: '杂项'
}
// 分组手动显示顺序。未列出的分组按字典序排到末尾。
// 这里手动指定是为了让"论文抓取"能夹在"机器学习"和"杂项"之间
// （单凭字典序 paper-digest > miscellaneous，会排到最后）。
const groupOrder = ['machine-learning', 'paper-digest', 'miscellaneous']
const ROOT_GROUP = '__root__'

// 按一级目录分组：machine-learning/00-prelude -> 组 "machine-learning"；
// 顶层文件（无子目录）放入特殊根分组，渲染时单独处理
type Group = { key: string; items: CollectionEntry<'blog'>[] }
const groups: Group[] = []
for (const p of sortedPosts) {
  const segments = p.id.split('/')
  const key = segments.length > 1 ? segments[0] : ROOT_GROUP
  let g = groups.find((x) => x.key === key)
  if (!g) {
    g = { key, items: [] }
    groups.push(g)
  }
  g.items.push(p)
}

// 把分组按 groupOrder 重排；根分组（顶层散文件）始终放最前
groups.sort((a, b) => {
  if (a.key === ROOT_GROUP) return -1
  if (b.key === ROOT_GROUP) return 1
  const ai = groupOrder.indexOf(a.key)
  const bi = groupOrder.indexOf(b.key)
  if (ai === -1 && bi === -1) return a.key.localeCompare(b.key)
  if (ai === -1) return 1
  if (bi === -1) return -1
  return ai - bi
})

const displayName = (key: string) => groupNameMap[key] ?? key
---

<nav class:list={['text-sm', className]} aria-label='笔记目录'>
  <ul class='flex flex-col gap-y-3'>
    {
      groups.map((g) => {
        // 渲染分组下的链接列表，避免根分组与具名分组各写一遍
        const linkList = (
          <ul
            class:list={[
              'flex flex-col gap-y-1',
              g.key !== ROOT_GROUP && 'border-l border-muted-foreground/20 ps-3'
            ]}
          >
            {g.items.map((p) => {
              const isCurrent = currentId === p.id
              return (
                <li>
                  <a
                    href={`/blog/${p.id}`}
                    aria-current={isCurrent ? 'page' : undefined}
                    class:list={[
                      'block rounded-md px-2 py-1 transition-colors hover:bg-muted hover:text-foreground',
                      isCurrent
                        ? 'bg-muted font-medium text-[var(--primary)]'
                        : 'text-muted-foreground'
                    ]}
                  >
                    {p.data.title}
                  </a>
                </li>
              )
            })}
          </ul>
        )
        // 根分组（顶层散文件）没有可折叠的容器，直接铺开
        if (g.key === ROOT_GROUP) {
          return <li>{linkList}</li>
        }
        // 仅当当前所在文章属于此分组时默认展开（保留位置感），其他分组保持收起
        const isCurrentGroup = g.items.some((p) => p.id === currentId)
        return (
          <li>
            <details open={isCurrentGroup} class='note-group'>
              <summary class='mb-2 flex cursor-pointer select-none items-center gap-1.5 text-base font-medium text-foreground'>
                <svg
                  class='chevron h-3.5 w-3.5 shrink-0 transition-transform'
                  viewBox='0 0 20 20'
                  fill='currentColor'
                  aria-hidden='true'
                >
                  <path d='M7.05 4.55a.75.75 0 0 1 1.06 0l4.9 4.9a.75.75 0 0 1 0 1.06l-4.9 4.9a.75.75 0 0 1-1.06-1.06L11.38 10 7.05 5.61a.75.75 0 0 1 0-1.06Z' />
                </svg>
                {displayName(g.key)}
              </summary>
              {linkList}
            </details>
          </li>
        )
      })
    }
  </ul>
</nav>

<style>
  /* 去掉 details/summary 默认的展开三角（不同浏览器实现不同），统一用上面的 SVG 图标 */
  .note-group > summary {
    list-style: none;
  }
  .note-group > summary::-webkit-details-marker {
    display: none;
  }
  /* 展开时把 chevron 从指向右旋转到指向下 */
  .note-group[open] > summary .chevron {
    transform: rotate(90deg);
  }
</style>
