---
import type { CollectionEntry } from 'astro:content'

import BlogDirectory from '@/components/blog/Directory.astro'

interface Props {
  section: { title: string; link: string }
  posts: CollectionEntry<'blog'>[]
  currentBlogId?: string
}

const { section, posts, currentBlogId } = Astro.props

type SubLink = { title: string; href: string }

// 这些是各页面原本传给 SectionNav 的 headings。放到全局侧栏后，用户在任意
// 页面点击一级菜单，都能先看到真正的子标题，再决定进入哪个具体位置。
const subLinksBySection: Record<string, SubLink[]> = {
  '/': [{ title: '首页', href: '/' }],
  '/tools': [{ title: '工具列表', href: '/tools' }],
  '/entertainment': [
    { title: '📺 YouTube 订阅频道', href: '/entertainment#youtube' },
    { title: '🎵 乐队', href: '/entertainment#bands' },
    { title: '🎬 电影', href: '/entertainment#movies' },
    { title: '📚 书籍', href: '/entertainment#books' }
  ],
  '/desksetup': [
    { title: '🪴 时间线', href: '/desksetup#timeline' },
    { title: '🍎 Apple', href: '/desksetup#apple' },
    { title: '🖥️ 外设', href: '/desksetup#peripherals' },
    { title: '🎧 发烧', href: '/desksetup#audio' }
  ]
}

const links = subLinksBySection[section.link] ?? [
  { title: section.title, href: section.link }
]
---

{
  section.link === '/blog' ? (
    <BlogDirectory {posts} currentId={currentBlogId} />
  ) : (
    <nav aria-label={`${section.title} 子菜单`}>
      <ul class='flex flex-col gap-y-1'>
        {links.map((item) => (
          <li>
            <a
              href={item.href}
              data-astro-prefetch
              class='block rounded-md px-2 py-1 text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground'
            >
              {item.title}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
