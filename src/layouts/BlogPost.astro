---
import type { MarkdownHeading } from 'astro'
import type { CollectionEntry } from 'astro:content'

// Plugin styles
import 'katex/dist/katex.min.css'

import { MediumZoom } from 'astro-pure/advanced'
import { ArticleBottom, Hero } from 'astro-pure/components/pages'
import config from 'virtual:config'
import PageLayout from '@/layouts/ContentLayout.astro'
import BlogDirectory from '@/components/blog/Directory.astro'

interface Props {
  post: CollectionEntry<'blog'>
  posts: CollectionEntry<'blog'>[]
  headings: MarkdownHeading[]
  remarkPluginFrontmatter: Record<string, unknown>
}

const {
  post: { id, data },
  posts,
  remarkPluginFrontmatter
} = Astro.props

const { heroImage, publishDate, title, updatedDate } = data

// ArticleBottom 取 collections[index-1] 当作 prev、index+1 当作 next。
// 1) 传入的 posts 由 sortMDByDate 按日期倒序排，对带序号的章节笔记（00-、01-）会让"序号大的"
//    反而排在前，导致页面底部的"上一篇 / 下一篇"指向反向。这里改用 id 升序（与左侧 Directory 一致），
//    让 prev = 上一章（更早的序号），next = 下一章（更晚的序号）。
// 2) 仅在"同一个子板块"内做前后翻页（id 第一段相同，例如都属于 machine-learning），避免
//    在 ML 末章点"下一篇"直接跳到 miscellaneous 或 paper-digest 这种跨主题的尴尬切换。
//    没有子目录的顶层文件归到一个独立的根分组，互相之间也不串。
const groupKey = (postId: string) => {
  const segments = postId.split('/')
  return segments.length > 1 ? segments[0] : '__root__'
}
const currentGroup = groupKey(id)
const orderedPosts = [...posts]
  .filter((p) => groupKey(p.id) === currentGroup)
  .sort((a, b) => a.id.localeCompare(b.id))

const socialImage = heroImage
  ? typeof heroImage.src === 'string'
    ? heroImage.src
    : heroImage.src.src
  : config.socialCard
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString()
const primaryColor = data.heroImage?.color ?? 'hsl(var(--primary) / var(--un-text-opacity))'
---

<PageLayout
  meta={{ articleDate, ogImage: socialImage, title }}
  highlightColor={primaryColor}
  back='/'
>
  <BlogDirectory {posts} currentId={id} slot='sidebar' />

  <Hero {data} {remarkPluginFrontmatter} slot='header' />

  <slot />

  <Fragment slot='bottom'>
    {/* Article recommend */}
    <ArticleBottom collections={orderedPosts} {id} class='mt-3 sm:mt-6' />
  </Fragment>

  <slot name='bottom-sidebar' slot='bottom-sidebar' />
</PageLayout>

{/*
  Hero 组件无条件渲染 <blockquote><q>{description}</q></blockquote>，浏览器对 <q> 默认
  添加 open-quote / close-quote 引号符号；当 description 为空时会显示成一对空引号 ""。
  我们已从 schema 中移除 description，所以这里直接隐藏整个斜体块。is:global 是因为
  Hero 来自 node_modules，无法直接修改其作用域样式。
*/}
<style is:global>
  .article-info > .italic.mt-3 {
    display: none;
  }
</style>

{config.integ.mediumZoom.enable && <MediumZoom />}
