---
import { Footer } from 'astro-pure/components/basic'
import type { SiteMeta } from 'astro-pure/types'
import BaseHead from '@/components/BaseHead.astro'
import Header from '@/components/Header.astro'
import SectionSidebar from '@/components/SectionSidebar.astro'
import config from '@/site-config'

// Import the global.css file here so that it is included on
// all pages through the use of the <BaseLayout /> component.
import '@/assets/styles/global.css'
import '@/assets/styles/app.css'

interface Props {
  meta: SiteMeta
  highlightColor?: string
  showSidebar?: boolean
}

const {
  meta: { articleDate, description = config.description, ogImage, title },
  highlightColor,
  showSidebar = true,
  ...props
} = Astro.props
const hasSubNav = Astro.slots.has('nav-sub')
---

<html lang={config.locale.lang}>
  <head>
    <BaseHead {articleDate} {description} {ogImage} {title} />
    {/*
      强制锁定为暗色主题：原 ThemeProvider 会读 localStorage / 系统偏好来决定明暗，
      用户希望只用暗色，所以这里直接给 <html> 加 dark class 并清掉可能残留的旧偏好，
      避免页面在加载时短暂 flash 成亮色。
    */}
    <script is:inline>
      ;(function () {
        document.documentElement.classList.add('dark')
        try {
          localStorage.setItem('theme', 'dark')
        } catch (e) {}
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute('content', '#0B0B10')
      })()
    </script>
  </head>

  <body class='flex justify-center bg-background text-foreground site-bg' {...props}>
    {
      highlightColor && (
        <div
          id='highlight-gradient'
          class='pointer-events-none absolute start-0 top-0 z-0 h-screen w-full opacity-25'
          style={`background-image:linear-gradient(${highlightColor},transparent)`}
        />
      )
    }
    <div
      id='main-container'
      class='w-full max-w-[96rem] min-h-[100dvh] flex'
    >
      {/* 移动抽屉始终存在；showSidebar 只控制桌面侧栏。 */}
      <SectionSidebar showDesktop={showSidebar} {hasSubNav}>
        {hasSubNav && <slot name='nav-sub' slot='nav-sub' />}
      </SectionSidebar>
      <div class='flex-1 min-w-0 flex flex-col justify-between'>
        <Header />
        <div class='flex-1 w-full'>
          <slot />
        </div>
        <Footer />
      </div>
    </div>

    {/* Set highlight color */}
    <style define:vars={{ highlightColor }}>
      :global(.highlight) {
        --highlight-fg: color-mix(
          in srgb,
          var(--highlightColor) 40%,
          hsl(var(--foreground)/var(--un-text-opacity, 1))
        );
        color: var(--highlight-fg, hsl(var(--primary) / var(--un-text-opacity))) !important;
      }
      :global(.highlight-bg) {
        background-color: var(
          --highlightColor,
          hsl(var(--primary) / var(--un-text-opacity))
        ) !important;
      }

      /* Extend safe area for some special screens
       * https://developer.mozilla.org/en-US/docs/Web/CSS/Reference/Values/env
       * https://webkit.org/blog/7929/designing-websites-for-iphone-x/
       */
      #main-container {
        padding-top: env(safe-area-inset-top);
        padding-left: calc(1rem + env(safe-area-inset-left));
        padding-right: calc(1rem + env(safe-area-inset-right));
      }
      @media (min-width: 640px) {
        #main-container {
          padding-left: calc(1.75rem + env(safe-area-inset-left));
          padding-right: calc(1.75rem + env(safe-area-inset-right));
        }
      }
      @media (min-width: 1024px) {
        #main-container {
          padding-left: calc(2.5rem + env(safe-area-inset-left));
          padding-right: calc(2.5rem + env(safe-area-inset-right));
        }
      }
    </style>
  </body>
</html>
