---
import type { SiteMeta } from 'astro-pure/types'
import { Button } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import PageLayout from '@/layouts/BaseLayout.astro'
import { integ } from '@/site-config'

interface Props {
  meta: SiteMeta & { modifiedDate?: string }
  highlightColor?: string
  back?: string
}

// 内层不再独立渲染 aside —— 子板块导航统一交给全局 SectionSidebar。
// 调用方仍按 `slot='sidebar'` 传入子导航内容（保持历史 API 兼容），
// 这里只负责把这部分内容透传到 BaseLayout 的 `nav-sub` 槽。
const { meta, highlightColor, back = '/', ...props } = Astro.props

// 仅当调用方传入 toc slot（只有笔记页 BlogPost 会传）时，正文区才切成
// 「正文 + 右侧目录」两栏。CommonPage 不传该 slot，因此保持原来的单栏。
const hasToc = Astro.slots.has('toc')
---

<PageLayout {meta} {highlightColor} {...props}>
  {/* 子板块导航：上抛到全局 SectionSidebar 的 nav-sub 槽 */}
  <slot name='sidebar' slot='nav-sub' />

  <Button title='Back' href={back} variant='back' />
  <main class:list={['mt-6', hasToc && 'xl:flex xl:items-start xl:gap-x-8']}>
    <article class='min-w-0 grow'>
      {/* Content header */}
      <div id='content-header' class='animate'>
        <slot name='header' />
      </div>

      {/* Content */}
      <div
        id='content'
        class={cn(
          'max-w-none animate mt-8 md:min-w-[45ch] overflow-x-hidden',
          integ.typography.class
        )}
      >
        <slot />
      </div>
    </article>

    {
      /* 右侧「本页目录」：仅笔记页（传入 toc slot 时）渲染，且只在宽屏显示。
         sticky 跟随滚动、过长时内部滚动。 */
      hasToc && (
        <aside
          aria-label='本页目录'
          class='animate sticky top-24 hidden max-h-[calc(100vh-7rem)] w-60 shrink-0 self-start overflow-y-auto xl:block'
        >
          <slot name='toc' />
        </aside>
      )
    }
  </main>

  <div class='bottom mt-6'>
    <div class='text-muted-foreground'>
      <slot name='bottom' />
    </div>
    {/* bottom-sidebar 历史接口保留但已不再渲染独立侧栏 */}
    <slot name='bottom-sidebar' />
  </div>
</PageLayout>
